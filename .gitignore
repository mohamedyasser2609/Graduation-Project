# ===========================================
# CCS (Code Composer Studio) / Eclipse CDT
# ===========================================
# Build output directories
Debug/
Release/

# CCS project settings (regenerated by IDE)
.settings/
.launches/
.ccsproject
.cproject
.project

# Target configuration (device-specific, regenerated)
targetConfigs/

# ===========================================
# Eclipse Workspace (parent directory files)
# ===========================================
.metadata/
.jxbrowser.userdata/
RemoteSystemsTempFiles/
dvt/

# ===========================================
# Build Artifacts
# ===========================================
*.obj
*.out
*.map
*.d
*.opt
*.mk
*.pp
*.xml

# Linker files (generated)
*_linkInfo.xml

# ===========================================
# Binary / Large Files
# ===========================================
*.pdf
*.bin
*.hex
*.elf

# ===========================================
# OS / Editor Generated
# ===========================================
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ===========================================
# Keep These (Override ignores if needed)
# ===========================================
# Keep the linker command file
!tm4c123gh6pm.cmd
# Keep git config
!.gitignore
!.gitattributes
